{
  "name": "snowify",
  "version": "2.0.0",
  "description": "A Spotify-like desktop music player that streams from free sources",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:mobile": "esbuild src/mobile/bridge.js --bundle --format=iife --global-name=__SnowifyMobile --outfile=src/renderer/mobile-bridge.js --platform=browser",
    "sync:android": "npx cap sync android",
    "apk": "npm run build:mobile && npx cap sync android && cd android && JAVA_HOME=/usr/lib/jvm/java-21-openjdk ./gradlew clean assembleDebug",
    "apk:install": "npm run apk && adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "build": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --linux --win",
    "publish": "electron-builder --linux --publish always",
    "publish:win": "electron-builder --win --publish always",
    "publish:mac": "electron-builder --mac --publish always",
    "publish:all": "electron-builder --linux --win --publish always"
  },
  "keywords": [
    "music",
    "player",
    "electron",
    "youtube",
    "streaming"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/status-bar": "^8.0.2",
    "@stef-0012/synclyrics": "^2.5.10",
    "@xhayper/discord-rpc": "^1.3.0",
    "electron-updater": "^6.8.3",
    "esbuild": "^0.27.4",
    "firebase": "^12.11.0",
    "https-proxy-agent": "^7.0.6",
    "music-metadata": "^7.14.0",
    "socks-proxy-agent": "^8.0.5",
    "youtubei.js": "^17.0.1",
    "ytmusic-api": "^5.3.1"
  },
  "build": {
    "appId": "com.nyaku.snowify",
    "productName": "Snowify",
    "icon": "assets/logo.png",
    "protocols": [
      {
        "name": "Snowify",
        "schemes": [
          "snowify"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Audio",
      "icon": "assets/logo.png",
      "mimeTypes": [
        "x-scheme-handler/snowify"
      ],
      "extraResources": [
        {
          "from": "bin/linux",
          "to": "bin/linux",
          "filter": [
            "yt-dlp"
          ]
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/logo.ico",
      "extraResources": [
        {
          "from": "bin/win",
          "to": "bin/win",
          "filter": [
            "yt-dlp.exe"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/logo.png",
      "category": "public.app-category.music"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "nyakuoff",
      "repo": "Snowify"
    }
  }
}
